{
  "name": "eidos-gen",
  "version": "0.1.0",
  "description": "Generate typed Eidos resource() and action() declarations from an OpenAPI 3.x spec.",
  "author": "Aditya Raj",
  "license": "MIT",
  "bin": {
    "eidos-gen": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "js-yaml": "^5.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "openapi",
    "codegen",
    "eidos",
    "service-worker",
    "offline",
    "pwa"
  ],
  "homepage": "https://github.com/sweidos/eidos/tree/main/packages/eidos-gen#readme",
  "bugs": {
    "url": "https://github.com/sweidos/eidos/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sweidos/eidos.git",
    "directory": "packages/eidos-gen"
  },
  "engines": {
    "node": ">=18"
  }
}
