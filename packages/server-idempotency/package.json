{
  "name": "@sweidos/server-idempotency",
  "version": "0.1.0",
  "description": "Reference server-side idempotency middleware (Express/Hono) implementing the dedupe-store contract for Eidos neverLose actions.",
  "author": "Aditya Raj",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./express": "./dist/express.js",
    "./hono": "./dist/hono.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "express": "^5.2.1",
    "hono": "^4.12.26",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "express": ">=4",
    "hono": ">=4"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  },
  "keywords": [
    "idempotency",
    "eidos",
    "express",
    "hono",
    "offline",
    "neverLose"
  ],
  "homepage": "https://github.com/sweidos/eidos/tree/main/packages/server-idempotency#readme",
  "bugs": {
    "url": "https://github.com/sweidos/eidos/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sweidos/eidos.git",
    "directory": "packages/server-idempotency"
  },
  "engines": {
    "node": ">=18"
  }
}
