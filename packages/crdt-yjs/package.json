  "homepage": "https://github.com/sweidos/eidos/tree/main/packages/crdt-yjs#readme",
  "bugs": {
    "url": "https://github.com/sweidos/eidos/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sweidos/eidos.git",
