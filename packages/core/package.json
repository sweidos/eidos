{
  "name": "@sweidos/eidos",
  "version": "1.0.23",
  "description": "Describe intent. The runtime figures out how. An abstraction layer for offline-first web apps.",
  "author": "Aditya Raj",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "service-worker",
    "offline",
    "pwa",
    "cache",
    "indexeddb",
    "background-sync",
    "offline-first",
    "react"
  ],
  "homepage": "https://github.com/iamadi11/eidos",
  "repository": {
    "type": "git",
    "url": "https://github.com/iamadi11/eidos.git",
    "directory": "packages/core"
  },
  "main": "./dist/eidos.cjs.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/eidos.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./sw": {
      "default": "./dist/eidos-sw.js"
    },
    "./vite": {
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs.js",
      "types": "./dist/vite.d.ts"
    },
    "./query": {
      "import": "./dist/query.js",
      "require": "./dist/query.cjs.js",
      "types": "./dist/query.d.ts"
    },
    "./testing": {
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs.js",
      "types": "./dist/testing.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && vite build --config vite.cjs.config.ts && vite build --config vite.plugin.config.ts && vite build --config vite.query.config.ts && vite build --config vite.testing.config.ts && node scripts/copy-sw.mjs",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "vite": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.45.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.9",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^24.1.3",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^2.1.9"
  }
}
