{
  "name": "@sweidos/eidos",
  "version": "2.2.0",
  "description": "Describe intent. The runtime figures out how. An abstraction layer for offline-first web apps.",
  "author": "Aditya Raj",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "service-worker",
    "offline",
    "offline-first",
    "pwa",
    "cache",
    "cache-api",
    "indexeddb",
    "background-sync",
    "react",
    "svelte",
    "vue",
    "react-native",
    "queue",
    "optimistic-ui",
    "network-resilience"
  ],
  "homepage": "https://sweidos.vercel.app/overview",
  "bugs": {
    "url": "https://github.com/sweidos/eidos/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/iamadi11"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sweidos/eidos.git",
    "directory": "packages/core"
  },
  "main": "./dist/eidos.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "eidos": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/eidos.cjs"
    },
    "./sw": {
      "default": "./dist/eidos-sw.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    },
    "./query": {
      "types": "./dist/query.d.ts",
      "import": "./dist/query.js",
      "require": "./dist/query.cjs"
    },
    "./push": {
      "types": "./dist/push.d.ts",
      "import": "./dist/push.js",
      "require": "./dist/push.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    },
    "./nextjs": {
      "types": "./dist/nextjs.d.ts",
      "import": "./dist/nextjs.js"
    },
    "./sveltekit": {
      "types": "./dist/sveltekit.d.ts",
      "import": "./dist/sveltekit.js"
    },
    "./devtools": {
      "types": "./dist/devtools.d.ts",
      "import": "./dist/devtools.js"
    },
    "./react-native": {
      "types": "./dist/react-native.d.ts",
      "import": "./dist/react-native.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && vite build --config vite.cjs.config.ts && vite build --config vite.plugin.config.ts && vite build --config vite.query.config.ts && vite build --config vite.push.config.ts && vite build --config vite.testing.config.ts && vite build --config vite.nextjs.config.ts && vite build --config vite.sveltekit.config.ts && vite build --config vite.devtools.config.ts && vite build --config vite.react-native.config.ts && vite build --config vite.cli.config.ts && node scripts/copy-sw.mjs",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench run",
    "test:coverage": "vitest run --coverage",
    "size": "size-limit",
    "prepublishOnly": "pnpm build"
  },
  "size-limit": [
    {
      "name": "core (resource + action + store)",
      "path": "dist/index.js",
      "limit": "7 KB"
    },
    {
      "name": "react hooks",
      "path": "dist/react/hooks.js",
      "limit": "1.5 KB"
    },
    {
      "name": "cjs bundle",
      "path": "dist/eidos.cjs",
      "limit": "18 KB"
    }
  ],
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "vite": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^12.1.0",
    "@tanstack/react-query": "^5.45.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "size-limit": "^12.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  }
}
