# Browserbase credentials — get from https://browserbase.com/settings
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Anthropic API key — powers act() and extract() via Claude
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Override the target URL (default: deployed Vercel playground)
# PLAYGROUND_URL=http://localhost:3000
