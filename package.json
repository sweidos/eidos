{
  "name": "eidos-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @eidos/playground dev",
    "build": "pnpm --filter @eidos/core build && pnpm --filter @eidos/playground build",
    "build:core": "pnpm --filter @eidos/core build",
    "build:worker": "pnpm --filter @eidos/worker build",
    "build:playground": "pnpm --filter @eidos/playground build",
    "type-check": "pnpm -r type-check",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec -- rm -rf dist node_modules .turbo",
    "publish:dry": "pnpm --filter @eidos/core publish --dry-run",
    "publish:core": "pnpm --filter @eidos/core publish --access public"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
