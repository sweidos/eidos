{
  "name": "eidos-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "preinstall": "node -e \"if(process.env.npm_execpath&&!process.env.npm_execpath.includes('pnpm'))throw new Error('Use pnpm, not npm or yarn. Run: corepack enable && pnpm install')\"",
    "dev": "pnpm --filter @eidos/playground dev",
    "build": "pnpm --filter @sweidos/eidos build && pnpm --filter @eidos/playground build",
    "build:core": "pnpm --filter @sweidos/eidos build",
    "build:worker": "pnpm --filter @eidos/worker build",
    "build:playground": "pnpm --filter @eidos/playground build",
    "type-check": "pnpm -r type-check",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec -- rm -rf dist node_modules .turbo",
    "publish:dry": "pnpm --filter @sweidos/eidos publish --dry-run",
    "publish:core": "pnpm --filter @sweidos/eidos publish --access public",
    "test:e2e": "pnpm --filter @eidos/e2e test",
    "test:e2e:watch": "pnpm --filter @eidos/e2e test:watch"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
